{
  "name": "@apoxy/console-core",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "types": "./src/index.ts",
  "exports": {
    ".": { "types": "./src/index.ts", "default": "./src/index.ts" },
    "./tokens.css": "./src/tokens.css",
    "./components": { "types": "./src/components/ui/index.ts", "default": "./src/components/ui/index.ts" },
    "./lib": { "types": "./src/lib/index.ts", "default": "./src/lib/index.ts" },
    "./schema": { "types": "./src/schema/schema.d.ts" }
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
