{
  "name": "@apoxy/console",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm -C apps/apoxy-console dev",
    "codegen": "tsx scripts/generate-schema.ts",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openapi-typescript": "^7.6.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.16"
    }
  }
}
